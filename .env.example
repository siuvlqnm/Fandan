# Cloudflare D1
CLOUDFLARE_ACCOUNT_ID=""
CLOUDFLARE_DATABASE_ID=""
CLOUDFLARE_API_TOKEN=""
CLOUDFLARE_D1_TOKEN=""

# Set this to the deployed Worker or custom-domain origin in production.
ORIGIN="http://localhost:5173"

# Better Auth
# For production use 32 characters and generated with high entropy
# https://www.better-auth.com/docs/installation
BETTER_AUTH_SECRET="replace-this-development-secret-before-production"

# Optional Workers AI model overrides.
# In production these are Wrangler vars; sensitive external provider keys should be Worker secrets.
AI_DISH_MODEL="@cf/meta/llama-3.2-3b-instruct"
AI_MEAL_MODEL="@cf/meta/llama-3.1-8b-instruct-fast"
AI_PROVIDER_API_KEY=""
